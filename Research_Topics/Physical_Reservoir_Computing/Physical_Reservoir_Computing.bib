@article{alu2025roadmap,
  title = {Roadmap on Embodying Mechano-Intelligence and Computing in Functional Materials and Structures},
  author = {Al{\`u}, Andrea and Arrieta, Andres F and Dottore, Emanuela Del and Dickey, Michael and Ferracin, Samuele and Harne, Ryan and Hauser, Helmut and He, Qiguang and Hopkins, Jonathan B and Hyatt, Lance P and Li, Suyi and Mariani, Stefano and Mazzolai, Barbara and Mondini, Alessio and Pal, Aniket and Preston, Daniel J and Rajappan, Anoop and Raney, Jordan R and Reis, Pedro M and Sarles, Stephen A and Sitti, Metin and Ubamanyu, Uba K and {van Hecke}, Martin and Wang, K W},
